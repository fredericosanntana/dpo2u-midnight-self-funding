# Midnight Network Configuration
# Copy to .env and fill in your values

# Network: "preprod" or "undeployed" (local devnet)
MIDNIGHT_NETWORK_ID=preprod

# Wallet seed (hex) — for local devnet genesis wallet
# MIDNIGHT_RAW_SEED=your_hex_seed_here

# Indexer endpoints
INDEXER_HTTP_URL=https://indexer.preprod.midnight.network/api/v3/graphql
INDEXER_WS_URL=wss://indexer.preprod.midnight.network/api/v3/graphql/ws

# Node RPC
NODE_URL=wss://rpc.preprod.midnight.network

# Proof server (run locally)
PROOF_SERVER_URL=http://localhost:6300

# --- Local Devnet Overrides ---
# MIDNIGHT_NETWORK_ID=undeployed
# INDEXER_HTTP_URL=http://localhost:8088/api/v3/graphql
# INDEXER_WS_URL=ws://localhost:8088/api/v3/graphql/ws
# NODE_URL=ws://localhost:9944

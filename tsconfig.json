{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["scripts/**/*.ts", "src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist", "compact"]
}

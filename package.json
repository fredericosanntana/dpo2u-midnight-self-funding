{
  "name": "dpo2u-midnight-self-funding",
  "version": "1.0.0",
  "description": "DPO2U Self-Funding Protocol on Midnight Network — autonomous fee distribution with ZK proofs for compliance agents",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "deploy:local": "tsx scripts/deploy-all.ts --network local",
    "deploy:preprod": "tsx scripts/deploy-all.ts --network preprod",
    "demo": "tsx scripts/demo-flow.ts",
    "balance": "tsx scripts/check-balance.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "devnet:up": "docker compose up -d",
    "devnet:down": "docker compose down",
    "ui:data": "tsx scripts/generate-ui-data.ts",
    "ui:dev": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "ui:preview": "cd ui && npm run preview"
  },
  "keywords": [
    "midnightntwrk",
    "compact",
    "zk-proofs",
    "self-funding",
    "autonomous-agents",
    "privacy",
    "compliance"
  ],
  "author": "DPO2U <contact@dpo2u.com>",
  "license": "MIT",
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.14.0",
    "@midnight-ntwrk/compact-js": "2.4.0",
    "@midnight-ntwrk/ledger-v7": "7.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "^3.1.0",
    "@midnight-ntwrk/midnight-js-fetch-zk-config-provider": "^3.1.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "^3.1.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "^3.1.0",
    "@midnight-ntwrk/midnight-js-network-id": "^3.1.0",
    "@midnight-ntwrk/midnight-js-types": "^3.1.0",
    "@midnight-ntwrk/wallet": "^5.0.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^1.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^1.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "^3.0.0",
    "@midnight-ntwrk/wallet-sdk-shielded": "^1.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^1.0.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "@scure/bip39": "^2.0.1",
    "bech32": "^2.0.0",
    "effect": "^3.0.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
